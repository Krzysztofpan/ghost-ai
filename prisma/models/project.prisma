enum ProjectStatus {
  DRAFT
  ARCHIVED
}

model Project {
  id                String                @id @default(cuid())
  ownerId           String
  name              String
  description       String?
  status            ProjectStatus         @default(DRAFT)
  canvasJsonPath    String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  collaborators     ProjectCollaborator[]

  @@index([ownerId])
  @@index([createdAt])
}

model ProjectCollaborator {
  id                String   @id @default(cuid())
  projectId         String
  email             String   @map("collaboratorEmail")
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email], map: "ProjectCollaborator_projectId_collaboratorEmail_key")
  @@index([email], map: "ProjectCollaborator_collaboratorEmail_idx")
  @@index([projectId, createdAt])
}
